            "no": 1
          },
          {
            "question": "下列关于HTML和JavaScript说法正确的有（ ）",
            "options": {
              "A": "HTML用于搭建网页静态结构",
              "B": "JavaScript是客户端脚本语言",
              "C": "JavaScript可以嵌入JSP页面中",
              "D": "HTML可以直接实现动态数据交互"
            },
            "answer": "ABC",
            "id": 2,
            "no": 2
          }
        ],
        "填空题": [
          {
            "question": "JSP的全称是（ ）。",
            "answer": "JavaServerPages（Java服务器页面）",
            "id": 1,
            "no": 1
          },
          {
            "question": "JSP页面首次运行时，会被服务器翻译成（ ）文件并编译运行。",
            "answer": "Servlet（Java）",
            "id": 2,
            "no": 2
          }
        ],
        "判断题": [
          {
            "question": "Tomcat是一款开源的JSP/Servlet容器，属于Web服务器。（ ）",
            "answer": "正确",
            "id": 1,
            "no": 1
          },
          {
            "question": "JSP代码运行在客户端，JavaScript代码运行在服务器端。（ ）",
            "answer": "错误",
            "id": 2,
            "no": 2
          }
        ],
        "简答题": [
          {
            "question": "简述JSP的运行原理。",
            "answer": "客户端浏览器发送JSP页面请求至Tomcat服务器，服务器接收请求后，检查JSP文件是否已编译；首次访问时，服务器将JSP页面翻译为ServletJava文件，再编译为class字节码文件，加载并运行该Servlet，动态生成HTML页面，最终将静态HTML响应返回给客户端浏览器渲染显示。后续访问可直接执行编译后的class文件，提升访问速度。",
            "id": 1,
            "no": 1
          }
        ]
      }
